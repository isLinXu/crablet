{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "beforeBundle": "",
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Crablet",
    "version": "0.1.0"
  },
  "plugins": {},
  "tauri": {
    "bundle": {
      "active": true,
      "targets": ["dmg", "nsis"],
      "icon": [
        "icons/icon.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": {
        "binaries/crablet-aarch64-apple-darwin": "CRABLET_RESOURCE_DIR"
      },
      "macOS": {
        "minimumSystemVersion": "10.15",
        "entitlements": "entitlements.mac.plist",
        "signingIdentity": null,
        "hardenedRuntime": true,
        "gatekeeperAssess": false
      },
      "windows": {
        "webviewInstallMode": {
          "type": "downloadBootstrapper"
        }
      }
    },
    "windows": [
      {
        "title": "Crablet",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "/splash.html",
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; connect-src 'self' http://localhost:*"
    }
  }
}
