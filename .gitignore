# =============================================================================
# Crablet Root .gitignore
# =============================================================================

# =============================================================================
# Environment Variables (NEVER COMMIT)
# =============================================================================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
./crablet/.env
*.local

# =============================================================================
# Database Files
# =============================================================================
*.db
*.db-shm
*.db-wal
*.db.bak_*
*.sqlite
*.sqlite3

# =============================================================================
# Logs
# =============================================================================
/logs/*
!/logs/.gitkeep
*.log

# =============================================================================
# Rust Build Output
# =============================================================================
/target
**/target/
**/*.rs.bk
Cargo.lock.bak

# =============================================================================
# Frontend Build Output
# =============================================================================
/frontend/dist
/frontend/node_modules
/frontend/.vite
node_modules/
**/node_modules/

# =============================================================================
# Tauri Desktop Sidecar & Generated
# =============================================================================
/desktop/binaries/
/desktop/gen/schemas/

# =============================================================================
# Packaging Output
# =============================================================================
/output/
*.dmg
*.app/
*-setup.exe

# =============================================================================
# Uploads
# =============================================================================
/uploads/
/crablet/uploads/

# =============================================================================
# Model Cache
# =============================================================================
.fastembed_cache/
**/.fastembed_cache/

# =============================================================================
# IDE and Editors
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
*.iml
.project
.classpath
.settings/
.qoder/
.trae/
.workbuddy/

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
**/.DS_Store
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
# Keys and Certificates (NEVER COMMIT)
# =============================================================================
*.pem
*.key
*.crt
*.p12
*.pfx
*.cer
*.der

# =============================================================================
# Docker Volumes (if stored locally)
# =============================================================================
/volumes/
/data/

# =============================================================================
# Temporary Files
# =============================================================================
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig

# =============================================================================
# Test Outputs
# =============================================================================
/test-results/
/coverage/
*.profraw

# =============================================================================
# Archives & Temp Research Reports
# =============================================================================
_archive_temp/
crablet/memory/
crablet/research_report_*.md

# =============================================================================
# Non-code Artifacts
# =============================================================================
PPT分享大纲_*.md

# =============================================================================
# Session Temp Directories
# =============================================================================
.session_tmps/
.box-desens/

# =============================================================================
# Python bytecode
# =============================================================================
__pycache__/
*.pyc
*.pyo

# =============================================================================
# Runtime data
# =============================================================================
.crablet/
