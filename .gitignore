# =============================================================================
# Crablet Root .gitignore
# =============================================================================

# =============================================================================
# Environment Variables (NEVER COMMIT)
# =============================================================================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
./crablet/.env

# =============================================================================
# Database Files
# =============================================================================
*.db
*.db-shm
*.db-wal
*.db.bak_*
*.sqlite
*.sqlite3

# =============================================================================
# Logs
# =============================================================================
/logs/*
!/logs/.gitkeep
*.log

# =============================================================================
# Rust Build Output
# =============================================================================
/target
**/target
**/*.rs.bak
Cargo.lock

# =============================================================================
# Frontend Build Output
# =============================================================================
/frontend/dist
/frontend/node_modules
/frontend/.vite
**/node_modules

# =============================================================================
# IDE and Editors
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
*.iml
.project
.classpath
.settings/

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
# Keys and Certificates (NEVER COMMIT)
# =============================================================================
*.pem
*.key
*.crt
*.p12
*.pfx
*.cer
*.der

# =============================================================================
# Docker Volumes (if stored locally)
# =============================================================================
/volumes/
/data/

# =============================================================================
# Temporary Files
# =============================================================================
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig

# =============================================================================
# Test Outputs
# =============================================================================
/test-results/
/coverage/
*.profraw
